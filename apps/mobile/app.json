{
  "expo": {
    "name": "Expt",
    "slug": "expt-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F3EE"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fun.expt.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F4F3EE"
      },
      "package": "fun.expt.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "expt",
    "plugins": [
      "expo-router"
    ]
  }
}
